APP_NAME=AI-Assisted Counseling Simulator
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Use the asyncpg driver. When running via docker-compose, host is "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/counseling_simulator

GEMINI_API_KEY=replace_me
GEMINI_CLIENT_MODEL=gemini-2.0-flash
GEMINI_EVALUATOR_MODEL=gemini-2.0-flash

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

MAX_SESSION_MESSAGES=20
MIN_STUDENT_MESSAGES=4
