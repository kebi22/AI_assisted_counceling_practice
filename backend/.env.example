APP_NAME=AI-Assisted Counseling Simulator
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Use the asyncpg driver. When running via docker-compose, host is "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/counseling_simulator

# Use "gemini_developer_api" with an AI Studio key, or "vertex_ai" with ADC.
AI_PROVIDER=gemini_developer_api
GEMINI_API_KEY=replace_me
GOOGLE_CLOUD_PROJECT=groupkac
GOOGLE_CLOUD_LOCATION=global
GEMINI_CLIENT_MODEL=gemini-2.5-flash
GEMINI_EVALUATOR_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

MAX_SESSION_MESSAGES=20
MIN_STUDENT_MESSAGES=4
